# ─── Copie para .env e preencha ──────────────────────────────────────────────
# No Kaggle: use Secrets (Settings > Add-ons > Secrets)
# Localmente: renomeie para .env (nunca commit este arquivo!)

# ── g4f.dev API Key (ÚNICO token necessário para todos os LLMs) ───────────────
# Obtenha em: https://g4f.dev → fazer login → Dashboard → API Keys → Create Key
# Todos os modelos (Gemini Flash, GLM, MiniMax, Qwen) usam esta mesma chave
G4F_API_KEY=g4f_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Discord ───────────────────────────────────────────────────────────────────
# Crie o bot em: https://discord.com/developers/applications
DISCORD_TOKEN=seu_discord_bot_token_aqui
DISCORD_GUILD_ID=id_numerico_do_seu_servidor

# ── HuggingFace (só para geração de imagem/vídeo local no Kaggle) ─────────────
# Crie em: https://huggingface.co/settings/tokens → New token (Read)
# Necessário para baixar Z-Image-Turbo e LTX-2.3
# Se não for usar geração de mídia, deixe vazio
HF_TOKEN=hf_seu_token_aqui
